# =============================================================================
# Peicosy Environment Variables
# Copy this file to .env and fill in your values
# =============================================================================

# --- Database ---
DATABASE_URL=postgresql://user:password@localhost:5432/peicosy

# --- Session ---
SESSION_SECRET=generate-a-random-string-at-least-32-characters

# --- Admin Credentials (seeded on first run) ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-to-a-strong-password

# --- DigitalOcean Spaces (S3-compatible object storage) ---
DO_SPACES_KEY=your-spaces-access-key-id
DO_SPACES_SECRET=your-spaces-secret-access-key
DO_SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
DO_SPACES_BUCKET=your-bucket-name
DO_SPACES_REGION=nyc3
DO_SPACES_CDN_ENDPOINT=https://your-bucket.nyc3.cdn.digitaloceanspaces.com

# --- Paynow (Zimbabwe payments) ---
PAYNOW_INTEGRATION_ID=your-paynow-integration-id
PAYNOW_INTEGRATION_KEY=your-paynow-integration-key

# --- PayFast (South Africa payments) ---
# PAYFAST_MERCHANT_ID=your-merchant-id
# PAYFAST_MERCHANT_KEY=your-merchant-key
# PAYFAST_PASSPHRASE=your-passphrase

# --- Application ---
APP_BASE_URL=https://your-domain.com
NODE_ENV=production
PORT=5000
